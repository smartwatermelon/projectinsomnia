---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Now">
  <h1>Now</h1>

  <div class="now-grid">
    <div class="now-left">
      <section class="feed-section">
        <h2 class="feed-heading">GitHub</h2>

        <div class="contribution-graph">
          <img
            src="https://ghchart.rshah.org/4338ca/smartwatermelon"
            alt="GitHub contribution graph"
            class="contribution-img"
            width="722"
            height="112"
          />
        </div>

        <details open class="activity-details">
          <summary class="activity-summary">Recent activity</summary>
          <div id="github-feed">
            <p class="muted">Loading…</p>
          </div>
        </details>

        <p class="profile-link">
          <a href="https://github.com/smartwatermelon" target="_blank" rel="noopener noreferrer">
            View full GitHub profile →
          </a>
        </p>
      </section>

      <section class="feed-section">
        <h2 class="feed-heading">Strava</h2>

        <details open class="activity-details">
          <summary class="activity-summary">Recent activities</summary>
          <div id="strava-feed">
            <p class="muted">Loading…</p>
          </div>
        </details>

        <p class="profile-link">
          <a href="https://www.strava.com/athletes/133350" target="_blank" rel="noopener noreferrer">
            View Strava profile →
          </a>
        </p>
      </section>
    </div>

    <div class="now-right">
      <section class="feed-section">
        <h2 class="feed-heading">Instagram</h2>
        <div id="instagram-feed">
          <p class="muted">Loading…</p>
        </div>
        <p class="profile-link">
          <a href="https://www.instagram.com/smartwatermelon/" target="_blank" rel="noopener noreferrer">
            View Instagram profile →
          </a>
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  function relativeTime(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const minutes = Math.floor(diff / 60_000);
    const hours = Math.floor(minutes / 60);
    const days = Math.floor(hours / 24);
    if (days > 0) return `${days}d ago`;
    if (hours > 0) return `${hours}h ago`;
    if (minutes > 0) return `${minutes}m ago`;
    return 'just now';
  }

  function showMessage(el: HTMLElement, text: string): void {
    const p = document.createElement('p');
    p.className = 'muted';
    p.textContent = text;
    el.replaceChildren(p);
  }

  function timedFetch(url: string): Promise<Response> {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), 10000);
    return fetch(url, { signal: controller.signal }).finally(() => clearTimeout(id));
  }

  // --- GitHub feed ---
  (async () => {
    const el = document.getElementById('github-feed')!;
    try {
      const res = await timedFetch('/api/github-feed');
      if (!res.ok) throw new Error(`${res.status}`);
      const { items } = await res.json() as {
        items: Array<{ title: string; link: string; published: string }>;
      };
      if (!items?.length) { showMessage(el, 'No recent public activity.'); return; }

      const ul = document.createElement('ul');
      ul.className = 'event-list';
      for (const item of items) {
        const li = document.createElement('li');
        li.className = 'event';

        const a = document.createElement('a');
        a.href = item.link;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'event-title';
        a.textContent = item.title;

        const span = document.createElement('span');
        span.className = 'event-time';
        span.textContent = relativeTime(item.published);

        li.append(a, span);
        ul.appendChild(li);
      }
      el.replaceChildren(ul);
    } catch {
      showMessage(el, 'Activity feed unavailable.');
    }
  })();

  // --- Strava feed ---
  (async () => {
    const el = document.getElementById('strava-feed')!;
    try {
      const res = await timedFetch('/api/strava-feed');
      if (!res.ok) throw new Error(`${res.status}`);
      const { items } = await res.json() as {
        items: Array<{ name: string; type: string; startDate: string; link: string }>;
      };
      if (!items?.length) { showMessage(el, 'No recent activities.'); return; }

      const ul = document.createElement('ul');
      ul.className = 'event-list';
      for (const item of items) {
        const li = document.createElement('li');
        li.className = 'event';

        const a = document.createElement('a');
        a.href = item.link;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'event-title';
        a.textContent = item.name;

        const type = document.createElement('span');
        type.className = 'event-type';
        type.textContent = item.type.replace(/([A-Z])/g, ' $1').trim();

        const time = document.createElement('span');
        time.className = 'event-time';
        time.textContent = relativeTime(item.startDate);

        li.append(a, type, time);
        ul.appendChild(li);
      }
      el.replaceChildren(ul);
    } catch {
      showMessage(el, 'Activity feed unavailable.');
    }
  })();

  // --- Instagram feed ---
  (async () => {
    const el = document.getElementById('instagram-feed')!;
    try {
      const res = await timedFetch('/api/instagram-feed');
      if (!res.ok) throw new Error(`${res.status}`);
      const { posts } = await res.json() as {
        posts: Array<{ imageUrl: string; caption: string; postUrl: string; timestamp: string }>;
      };
      if (!posts?.length) { showMessage(el, 'No recent posts.'); return; }

      const grid = document.createElement('div');
      grid.className = 'instagram-grid';

      for (const post of posts) {
        const a = document.createElement('a');
        a.href = post.postUrl;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'instagram-thumb-link';

        const img = document.createElement('img');
        img.src = post.imageUrl;
        img.alt = (post.caption ?? '').slice(0, 100);
        img.className = 'instagram-thumb';
        img.loading = 'lazy';

        a.appendChild(img);
        grid.appendChild(a);
      }
      el.replaceChildren(grid);
    } catch {
      showMessage(el, 'Feed unavailable.');
    }
  })();
</script>

<style>
  :global(main:has(.now-grid)) {
    max-width: 56rem;
  }

  .now-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 640px) {
    .now-grid {
      grid-template-columns: 1fr;
    }
  }

  .feed-section {
    margin-bottom: 3rem;
  }

  .feed-heading {
    margin-bottom: 1rem;
  }

  .contribution-graph {
    background: var(--color-surface);
    border-radius: 4px;
    overflow-x: auto;
    overflow-y: hidden;
    margin-bottom: 1.5rem;
  }

  .contribution-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .activity-details {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0 1rem;
  }

  .activity-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-muted);
    user-select: none;
  }

  .activity-summary::-webkit-details-marker {
    display: none;
  }

  .activity-summary::after {
    content: '▾';
    font-size: 1.1em;
    transition: transform 0.2s ease;
    color: var(--color-muted);
  }

  details:not([open]) .activity-summary::after {
    transform: rotate(-90deg);
  }

  /* JS-generated elements don't receive Astro's scoped attribute, so these must be global */
  :global(.event-list) {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
  }

  :global(.event) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.event:last-child) {
    border-bottom: none;
  }

  :global(.event-title) {
    font-size: 0.9rem;
    color: var(--color-text);
    text-decoration: none;
    flex: 1 1 100%;
    min-width: 0;
  }

  :global(.event-title:hover) {
    color: var(--color-accent);
  }

  :global(.event-type) {
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  :global(.event-time) {
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: auto;
  }

  :global(.instagram-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  :global(.instagram-thumb-link) {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  :global(.instagram-thumb) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }

  :global(.instagram-thumb:hover) {
    opacity: 0.85;
  }

  .profile-link {
    margin-top: 0.75rem;
    font-size: 0.9rem;
  }

  .profile-link a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .profile-link a:hover {
    text-decoration: underline;
  }

  :global(.muted) {
    color: var(--color-muted);
    padding: 0.75rem 0;
    margin: 0;
  }
</style>
