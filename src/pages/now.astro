---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getStore } from '@netlify/blobs';
import type { ActivityItem, GitHubActivity } from '../../netlify/functions/poll-github.mts';

// --- Read from Blob cache ---
let activity: GitHubActivity | null = null;

try {
  const store = getStore('now-feeds');
  activity = await store.get('github-activity', { type: 'json' }) as GitHubActivity | null;
} catch (e) {
  console.error('[now] Blob read failed:', e instanceof Error ? e.message : String(e));
}

// --- Helpers ---
function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const minutes = Math.floor(diff / 60_000);
  const hours   = Math.floor(minutes / 60);
  const days    = Math.floor(hours / 24);
  if (days > 0)    return `${days}d ago`;
  if (hours > 0)   return `${hours}h ago`;
  if (minutes > 0) return `${minutes}m ago`;
  return 'just now';
}

const lastFetched = activity?.lastFetched
  ? relativeTime(activity.lastFetched)
  : null;
const items: ActivityItem[] = activity?.items ?? [];
---

<BaseLayout title="Now">
  <h1>Now</h1>

  <section class="feed-section">
    <h2 class="feed-heading">GitHub</h2>

    <div class="contribution-graph">
      <img
        src="https://ghchart.rshah.org/4338ca/smartwatermelon"
        alt="GitHub contribution graph"
        class="contribution-img"
        width="722"
        height="112"
      />
    </div>

    <details open class="activity-details">
      <summary class="activity-summary">Recent activity</summary>

      {!activity && (
        <p class="muted">Activity feed initializing — check back soon.</p>
      )}

      {activity && items.length === 0 && (
        <p class="muted">No recent public activity.</p>
      )}

      {items.length > 0 && (
        <ul class="event-list">
          {items.map((item) => (
            <li class="event">
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="event-title"
              >
                {item.title}
              </a>
              <span class="event-time">{relativeTime(item.published)}</span>
            </li>
          ))}
        </ul>
      )}

      {lastFetched && (
        <p class="updated">Updated {lastFetched}</p>
      )}
    </details>

    <p class="github-profile-link">
      <a
        href="https://github.com/smartwatermelon"
        target="_blank"
        rel="noopener noreferrer"
      >
        View full GitHub profile →
      </a>
    </p>
  </section>
</BaseLayout>

<style>
  .feed-section {
    margin-bottom: 3rem;
  }

  .feed-heading {
    margin-bottom: 1rem;
  }

  .contribution-graph {
    background: var(--color-surface);
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 722 / 112;
    margin-bottom: 1.5rem;
  }

  .contribution-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .activity-details {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0 1rem;
  }

  .activity-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-muted);
    user-select: none;
  }

  .activity-summary::-webkit-details-marker {
    display: none;
  }

  .activity-summary::after {
    content: '▾';
    font-size: 1.1em;
    transition: transform 0.2s ease;
    color: var(--color-muted);
  }

  details:not([open]) .activity-summary::after {
    transform: rotate(-90deg);
  }

  .event-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
  }

  .event {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .event:last-child {
    border-bottom: none;
  }

  .event-title {
    font-size: 0.9rem;
    color: var(--color-text);
    text-decoration: none;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-title:hover {
    color: var(--color-accent);
  }

  .event-time {
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .updated {
    font-size: 0.8rem;
    color: var(--color-muted);
    padding: 0.5rem 0 0.75rem;
    margin: 0;
  }

  .github-profile-link {
    margin-top: 0.75rem;
    font-size: 0.9rem;
  }

  .github-profile-link a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .github-profile-link a:hover {
    text-decoration: underline;
  }

  .muted {
    color: var(--color-muted);
    padding: 0.75rem 0;
  }
</style>
