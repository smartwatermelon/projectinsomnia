---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Now">
  <h1>Now</h1>

  <section class="feed-section">
    <h2 class="feed-heading">GitHub</h2>

    <div class="contribution-graph">
      <img
        src="https://ghchart.rshah.org/4338ca/smartwatermelon"
        alt="GitHub contribution graph"
        class="contribution-img"
        width="722"
        height="112"
      />
    </div>

    <details open class="activity-details">
      <summary class="activity-summary">Recent activity</summary>
      <div id="github-feed">
        <p class="muted">Loading…</p>
      </div>
    </details>

    <p class="github-profile-link">
      <a
        href="https://github.com/smartwatermelon"
        target="_blank"
        rel="noopener noreferrer"
      >
        View full GitHub profile →
      </a>
    </p>
  </section>
</BaseLayout>

<script>
  const feedEl = document.getElementById('github-feed')!;

  function relativeTime(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const minutes = Math.floor(diff / 60_000);
    const hours = Math.floor(minutes / 60);
    const days = Math.floor(hours / 24);
    if (days > 0) return `${days}d ago`;
    if (hours > 0) return `${hours}h ago`;
    if (minutes > 0) return `${minutes}m ago`;
    return 'just now';
  }

  function showMessage(text: string): void {
    const p = document.createElement('p');
    p.className = 'muted';
    p.textContent = text;
    feedEl.replaceChildren(p);
  }

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);

  fetch('/api/github-feed', { signal: controller.signal })
    .then((res) => {
      if (!res.ok) throw new Error(`${res.status}`);
      return res.json();
    })
    .then(({ items }: { items: Array<{ title: string; link: string; published: string }> }) => {
      clearTimeout(timeout);

      if (!items?.length) {
        showMessage('No recent public activity.');
        return;
      }

      const ul = document.createElement('ul');
      ul.className = 'event-list';

      for (const item of items) {
        const li = document.createElement('li');
        li.className = 'event';

        const a = document.createElement('a');
        a.href = item.link;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'event-title';
        a.textContent = item.title;

        const span = document.createElement('span');
        span.className = 'event-time';
        span.textContent = relativeTime(item.published);

        li.append(a, span);
        ul.appendChild(li);
      }

      feedEl.replaceChildren(ul);
    })
    .catch(() => {
      clearTimeout(timeout);
      showMessage('Activity feed unavailable.');
    });
</script>

<style>
  .feed-section {
    margin-bottom: 3rem;
  }

  .feed-heading {
    margin-bottom: 1rem;
  }

  .contribution-graph {
    background: var(--color-surface);
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 722 / 112;
    margin-bottom: 1.5rem;
  }

  .contribution-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .activity-details {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0 1rem;
  }

  .activity-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-muted);
    user-select: none;
  }

  .activity-summary::-webkit-details-marker {
    display: none;
  }

  .activity-summary::after {
    content: '▾';
    font-size: 1.1em;
    transition: transform 0.2s ease;
    color: var(--color-muted);
  }

  details:not([open]) .activity-summary::after {
    transform: rotate(-90deg);
  }

  .event-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
  }

  .event {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .event:last-child {
    border-bottom: none;
  }

  .event-title {
    font-size: 0.9rem;
    color: var(--color-text);
    text-decoration: none;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-title:hover {
    color: var(--color-accent);
  }

  .event-time {
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .github-profile-link {
    margin-top: 0.75rem;
    font-size: 0.9rem;
  }

  .github-profile-link a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .github-profile-link a:hover {
    text-decoration: underline;
  }

  .muted {
    color: var(--color-muted);
    padding: 0.75rem 0;
    margin: 0;
  }
</style>
