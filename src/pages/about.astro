<style>
  .social-links {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, max-content);
    gap: 0.5rem 2.5rem;
    margin-bottom: 1.25rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.95rem;
    transition: color 0.15s;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  .social-links svg {
    width: 1.1em;
    height: 1.1em;
    fill: currentColor;
    flex-shrink: 0;
  }

  .social-note {
    color: var(--color-muted);
    font-size: 0.85em;
  }

  .affiliation-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, max-content);
    gap: 0.5rem 2.5rem;
    margin-bottom: 1.25rem;
  }

  .affiliation-list a {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.15s;
  }

  .affiliation-list a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 480px) {
    .social-links,
    .affiliation-list {
      grid-template-columns: 1fr;
    }
  }
</style>
